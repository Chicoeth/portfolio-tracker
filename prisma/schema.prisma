generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum WalletCategory {
  main
  thematic
  past
}

enum WalletStatus {
  active
  closed
}

enum RebalanceType {
  initial
  rebalance
  swap
  mixed
}

enum RiskLevel {
  low
  medium
  high
  very_high
}

// ─── Models ─────────────────────────────────────────────

model Wallet {
  id          String         @id @default(cuid())
  name        String
  description String         @db.Text
  category    WalletCategory
  status      WalletStatus   @default(active)
  closedAt    DateTime?      @map("closed_at")
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  compositions    WalletComposition[]
  rebalanceEvents RebalanceEvent[]

  @@map("wallets")
}

model Asset {
  ticker        String  @id
  displayName   String  @map("display_name")
  symbol        String
  riskLevel     RiskLevel @map("risk_level")
  description   String  @db.Text
  websiteUrl    String? @map("website_url")
  coingeckoUrl  String? @map("coingecko_url")
  tradingviewUrl String? @map("tradingview_url")
  defillamaUrl  String? @map("defillama_url")
  exchanges     Json    @default("[]")

  compositions WalletComposition[]
  dailyPrices  DailyPrice[]

  @@map("assets")
}

model RebalanceEvent {
  id             String        @id @default(cuid())
  walletId       String        @map("wallet_id")
  date           DateTime      @db.Date
  type           RebalanceType
  notes          String?       @db.Text
  portfolioValue Decimal       @default(100) @map("portfolio_value") @db.Decimal(18, 6)
  createdAt      DateTime      @default(now()) @map("created_at")

  wallet       Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)
  compositions WalletComposition[]

  @@unique([walletId, date])
  @@map("rebalance_events")
}

model WalletComposition {
  id        String    @id @default(cuid())
  walletId  String    @map("wallet_id")
  eventId   String    @map("event_id")
  assetId   String    @map("asset_id")
  weight    Decimal   @db.Decimal(5, 4) // e.g. 0.5000 = 50%
  startDate DateTime  @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date

  wallet Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  event  RebalanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  asset  Asset          @relation(fields: [assetId], references: [ticker])

  @@index([walletId, endDate])
  @@index([walletId, assetId])
  @@map("wallet_compositions")
}

model DailyPrice {
  assetId   String   @map("asset_id")
  date      DateTime @db.Date
  priceUsd  Decimal  @map("price_usd") @db.Decimal(18, 6)
  marketCap BigInt?  @map("market_cap")

  asset Asset @relation(fields: [assetId], references: [ticker])

  @@id([assetId, date])
  @@map("daily_prices")
}

model ExchangeRate {
  date   DateTime @id @db.Date
  usdBrl Decimal  @map("usd_brl") @db.Decimal(10, 4)

  @@map("exchange_rates")
}
